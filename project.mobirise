          "_name": "list04",
          "_sourceTheme": "startm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"list04\" group=\"List\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{\n  'mbr-fullscreen': fullScreen,\n  'mbr-parallax-background': bg.parallax}\">\n  <mbr-parameters>\n    <header>Size</header>\n    <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n    <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\">\n    <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n    <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n    <input type=\"range\" inline title=\"Content Width\" name=\"contentWidth\" min=\"8\" max=\"12\" step=\"1\" value=\"10\">\n    <header>Show/Hide</header>\n    <input type=\"checkbox\" title=\"Title\" name=\"showMainTitle\">\n    <input type=\"checkbox\" title=\"Subtitle\" name=\"showMainSubtitle\">\n    <input type=\"checkbox\" title=\"Paragraph Title\" name=\"showTitle\" checked>\n    <input type=\"color\" title=\"Wrap Bg\" name=\"wrapBgColor\" value=\"#ffffff\">\n    <header>Background</header>\n    <fieldset type=\"background\" name=\"bg\" parallax>\n      <input type=\"image\" title=\"Image\" value=\"../_images/background1.jpg\" parallax>\n      <input type=\"color\" title=\"Color\" value=\"#ffffff\" selected>\n      <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n    </fieldset>\n    <header condition=\"bg.type === 'video'\">Fallback Image</header>\n    <input type=\"image\" title=\"Fallback Image\" value=\"../_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n    <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n    <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#000000\" condition=\"overlay && bg.type !== 'color'\">\n    <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.4\" condition=\"overlay && bg.type !== 'color'\">\n  </mbr-parameters>\n\n  <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n  <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\"></div>\n  <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n    <div class=\"row justify-content-center\">\n      <div class=\"card col-md-12 col-lg-{{contentWidth}}\">\n        <div class=\"card-wrapper\">\n          <div class=\"row justify-content-center\">\n            <div class=\"col-12 mb-5 content-head\" mbr-if=\"showMainTitle || showMainSubtitle\">\n              <h3 class=\"card-title mbr-fonts-style mbr-white mt-3\" mbr-theme-style=\"display-2\" mbr-if=\"showMainTitle\" data-app-selector=\".card-title, .card-box\"><b>List:</b></h3>\n              <h5 class=\"mbr-section-subtitle mbr-fonts-style align-center mb-0 mt-4\" mbr-theme-style=\"display-7\" mbr-if=\"showMainSubtitle\" data-app-selector=\".mbr-section-subtitle\">\n                Lorem ipsum dolor sit amet, consectetur adipiscing elit.\n              </h5>\n            </div>\n          </div>\n\n          <div class=\"row justify-content-left item features-without-image mt-0 mb-5 active\">\n            <div class=\"col-12 col-md-12 col-lg-3\" mbr-if=\"showTitle\">\n              <h5 class=\"mbr-card-title mbr-fonts-style mt-0 mb-3\" mbr-if=\"showTitle\" data-app-selector=\".mbr-card-title\" mbr-theme-style=\"display-7\">\n                <b>Proizvođač</b></h5>\n            </div>\n            <div class=\"col-md-12 col-lg item-wrapper\">\n              <p class=\"mbr-text mbr-fonts-style mt-0 mb-0\" data-app-selector=\".mbr-text\" mbr-theme-style=\"display-7\">IKEA /&nbsp;MIDEA</p>\n            </div>\n          </div>\n          <div class=\"row justify-content-left item features-without-image mt-0 mb-5\">\n            <div class=\"col-12 col-md-12 col-lg-3\" mbr-if=\"showTitle\">\n              <h5 class=\"mbr-card-title mbr-fonts-style mt-0 mb-3\" mbr-if=\"showTitle\" data-app-selector=\".mbr-card-title\" mbr-theme-style=\"display-7\"><b>Garancija</b></h5>\n            </div>\n            <div class=\"col-md-12 col-lg item-wrapper\">\n              <p class=\"mbr-text mbr-fonts-style mt-0 mb-0\" data-app-selector=\".mbr-text\" mbr-theme-style=\"display-7\">2 godina</p>\n            </div>\n          </div>\n          <div class=\"row justify-content-left item features-without-image mt-0 mb-5\">\n\n            <div class=\"col-12 col-md-12 col-lg-3 \" mbr-if=\"showTitle\">\n              <h5 class=\"mbr-card-title mbr-fonts-style mt-0 mb-3\" mbr-if=\"showTitle\" data-app-selector=\".mbr-card-title\" mbr-theme-style=\"display-7\">\n                <b>IKEA serija</b></h5>\n            </div>\n            <div class=\"col-md-12 col-lg\">\n              <p class=\"mbr-text mbr-fonts-style mt-0 mb-0 item-wrapper\" data-app-selector=\".mbr-text\" mbr-theme-style=\"display-7\">TILLREDA</p>\n            </div>\n          </div><div class=\"row justify-content-left item features-without-image mt-0 mb-5\">\n\n            <div class=\"col-12 col-md-12 col-lg-3 \" mbr-if=\"showTitle\">\n              <h5 class=\"mbr-card-title mbr-fonts-style mt-0 mb-3\" mbr-if=\"showTitle\" data-app-selector=\".mbr-card-title\" mbr-theme-style=\"display-7\">\n                <b>Širina</b></h5>\n            </div>\n            <div class=\"col-md-12 col-lg\">\n              <p class=\"mbr-text mbr-fonts-style mt-0 mb-0 item-wrapper\" data-app-selector=\".mbr-text\" mbr-theme-style=\"display-7\">28 cm</p>\n            </div>\n          </div><div class=\"row justify-content-left item features-without-image mt-0 mb-5\">\n\n            <div class=\"col-12 col-md-12 col-lg-3 \" mbr-if=\"showTitle\">\n              <h5 class=\"mbr-card-title mbr-fonts-style mt-0 mb-3\" mbr-if=\"showTitle\" data-app-selector=\".mbr-card-title\" mbr-theme-style=\"display-7\">\n                <b>Ugradbeno / samostojeće</b></h5>\n            </div>\n            <div class=\"col-md-12 col-lg\">\n              <p class=\"mbr-text mbr-fonts-style mt-0 mb-0 item-wrapper\" data-app-selector=\".mbr-text\" mbr-theme-style=\"display-7\">Samostojeće</p>\n            </div>\n          </div><div class=\"row justify-content-left item features-without-image mt-0 mb-5\">\n\n            <div class=\"col-12 col-md-12 col-lg-3 \" mbr-if=\"showTitle\">\n              <h5 class=\"mbr-card-title mbr-fonts-style mt-0 mb-3\" mbr-if=\"showTitle\" data-app-selector=\".mbr-card-title\" mbr-theme-style=\"display-7\"><b>Dimenzije (V×Š×D)</b></h5>\n            </div>\n            <div class=\"col-md-12 col-lg\">\n              <p class=\"mbr-text mbr-fonts-style mt-0 mb-0 item-wrapper\" data-app-selector=\".mbr-text\" mbr-theme-style=\"display-7\">Širina: 28 cm<br>Dubina: 52 cm<br>Visina: 6.2 cm<br>Težina: 4.20 kg<br>Duljina kabla: 140 cm</p>\n            </div>\n          </div><div class=\"row justify-content-left item features-without-image mt-0 mb-5\">\n\n            <div class=\"col-12 col-md-12 col-lg-3 \" mbr-if=\"showTitle\">\n              <h5 class=\"mbr-card-title mbr-fonts-style mt-0 mb-3\" mbr-if=\"showTitle\" data-app-selector=\".mbr-card-title\" mbr-theme-style=\"display-7\"><b>Detaljni opis</b></h5>\n            </div>\n            <div class=\"col-md-12 col-lg\">\n              <p class=\"mbr-text mbr-fonts-style mt-0 mb-0 item-wrapper\" data-app-selector=\".mbr-text\" mbr-theme-style=\"display-7\">Možeš brzo početi kuhati jer se kuhalište lako uključi u struju s priloženom utičnicom.<br><br>Indukcijska kuhališta iznimno su energetski učinkovita, brza i precizna. Indukcijska tehnologija prenosi energiju izravno na magnetsko posuđe.<br><br>Kontrolna ploča na dodir i pritisak omogućuje lako i precizno reguliranje topline pritiskom na + i - simbole.<br><br>Prilikom korištenja, kuhalište uvijek stavi na ravnu, stabilnu površinu.</p>\n            </div>\n          </div><div class=\"row justify-content-left item features-without-image mt-0 mb-5\">\n\n            <div class=\"col-12 col-md-12 col-lg-3 \" mbr-if=\"showTitle\">\n              <h5 class=\"mbr-card-title mbr-fonts-style mt-0 mb-3\" mbr-if=\"showTitle\" data-app-selector=\".mbr-card-title\" mbr-theme-style=\"display-7\">\n                <b>Dobro je znati</b></h5>\n            </div>\n            <div class=\"col-md-12 col-lg\">\n              <p class=\"mbr-text mbr-fonts-style mt-0 mb-0 item-wrapper\" data-app-selector=\".mbr-text\" mbr-theme-style=\"display-7\">1 x 1500 W indukcijska zona.<br><br>1 x 2000 W indukcijska zona.<br><br>9 razina pečenja.<br><br>Kuhalište s indukcijskim zonama: 1 x 158 mm i 1 x 180 mm.<br><br>Priključna snaga: 3500 W.<br><br>Električni napon: 220 – 240 V.<br><br>Elektronički zaslon sa sigurnsnom zaštitom za djecu.<br><br>Ovaj proizvod nosi CE oznaku sukladnosti.<br><br>Ovaj proizvod nosi srpsku oznaku sukladnosti.<br><br>UPOZORENJE! Odabir pogrešne maksimalne snage može uzrokovati preopterećenje strujnog kruga u domu. Ako ne znaš kolika je snaga strujnog kruga u tvom domu, obrati se kvalificiranom električaru koji će je moći provjeriti.<br><br>Struja: 10 A (2200 W) ili 15 A (3500 W), ovisno o postavki mehaničkog prekidača.<br><br>Priložen je kabel.<br><br>U slučaju nedoumica o mogućnosti korištenja posuđa za kuhanje na indukcijskom kuhalištu, s pomoću magneta provjeriti je li dno magnetsko.<br><br>Kuhalište može proizvesti tiho zujanje, zviždanje ili otkucavanje. Ti su zvukovi uzrokovani indukcijskom tehnologijom i potpuno su normalni.<br><br>Indukcijska kuhališta zahtijevaju posuđe s magnetnim dnom.<br><br>Potpune informacije o instalaciji i upotrebi nalaze se ispod odjeljka Upute za sastavljanje i dokumenti.</p><div class=\"item-menu-overlay\" style=\"opacity: 0.885257;\"><div class=\"btn-wrapper\"><span class=\"mbr-icon-arrow-left ctrl-btn\"><span class=\"tooltiptext\">Move Left</span></span><span class=\"mbr-icon-arrow-right ctrl-btn\"><span class=\"tooltiptext\">Move Right</span></span><span class=\"mbr-icon-trash ctrl-btn\"><span class=\"tooltiptext\">Remove</span></span><span class=\"mbr-icon-plus ctrl-btn\"><span class=\"tooltiptext\">Add Copy</span></span></div></div><p></p>\n            </div>\n          </div>\n\n\n        </div>\n      </div>\n    </div>\n  </div>\n</section>",
          "_anchor": "list04-24",
          "_cid": "vdPJUPcHcg",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
